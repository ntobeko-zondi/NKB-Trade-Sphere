<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg">

    <!-- Handle -->
    <View
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:background="@color/sheet_handle" />

    <!-- Product image -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <ImageView
            android:id="@+id/ivSheetImage"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:contentDescription="@string/featured"
            android:scaleType="centerCrop" />

        <!-- Condition tag -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCondition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/sheet_photo_pill_bg"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/sheet_photo_pill_bg"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />
        </LinearLayout>

        <!-- Close button -->
        <ImageView
            android:id="@+id/ivSheetClose"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_gravity="top|end"
            android:layout_margin="14dp"
            android:background="@drawable/sheet_photo_pill_bg"
            android:src="@drawable/ic_search"
            app:tint="@color/text_primary"
            android:padding="10dp"
            android:contentDescription="@string/nav_home"
            android:clickable="true"
            android:focusable="true" />
    </FrameLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- Price row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSheetPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/orange"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSheetBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_bg"
                android:text="Featured"
                android:textColor="@color/badge_on_surface_text"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <!-- Name -->
        <TextView
            android:id="@+id/tvSheetName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold"
            android:layout_marginTop="5dp" />

        <!-- Location -->
        <TextView
            android:id="@+id/tvSheetLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginTop="7dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/sheet_divider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvSheetDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.6" />

        <!-- Seller card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:layout_marginTop="18dp">

            <TextView
                android:id="@+id/tvSellerAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_avatar_bg"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="13dp">

                <TextView
                    android:id="@+id/tvSellerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/verified_seller"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSellerRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/orange"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />
        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="22dp">

            <Button
                android:id="@+id/btnChat"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:text="@string/chat_with_seller"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="@color/orange"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/ivSheetSave"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_wishlist"
                app:tint="@color/orange"
                android:padding="14dp"
                android:contentDescription="@string/wishlist"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>