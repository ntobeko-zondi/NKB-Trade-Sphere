<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/onboarding_interest_backdrop">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginStart="-48dp"
        android:layout_marginTop="-40dp"
        android:background="@drawable/onboarding_orb_orange"
        android:importantForAccessibility="no" />

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="90dp"
        android:layout_marginEnd="-40dp"
        android:background="@drawable/onboarding_orb_peach"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="26dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/tvSkipInterests"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:background="@drawable/onboarding_badge_bg"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="@string/skip_for_now"
            android:textColor="@color/orange_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/onboardingCard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:background="@drawable/onboarding_interest_surface_bg"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="20dp"
            android:paddingEnd="18dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/onboarding_badge_bg"
                android:paddingStart="11dp"
                android:paddingTop="6dp"
                android:paddingEnd="11dp"
                android:paddingBottom="6dp"
                android:text="@string/welcome_to_tradesphere"
                android:textColor="@color/orange_dark"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/interests_title"
                android:textColor="@color/text_primary"
                android:textSize="29sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:lineSpacingMultiplier="1.3"
                android:text="@string/interests_subtitle"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSelectionMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/onboarding_badge_bg"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp"
                android:textColor="@color/orange_dark"
                android:textSize="11.5sp"
                android:textStyle="bold"
                tools:text="0 of 3 selected" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:overScrollMode="always">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupInterests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="8dp"
                    app:chipSpacingHorizontal="10dp"
                    app:chipSpacingVertical="10dp"
                    app:singleLine="false" />
            </ScrollView>

            <Button
                android:id="@+id/btnContinueInterests"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/orange"
                android:enabled="false"
                android:text="@string/continue_to_home"
                android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
