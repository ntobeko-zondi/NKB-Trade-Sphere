<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_body"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="28dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/onboarding_badge_bg"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp"
        android:text="@string/welcome_to_tradesphere"
        android:textColor="@color/orange_dark"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/interests_title"
        android:textColor="@color/text_primary"
        android:textSize="31sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingMultiplier="1.3"
        android:text="@string/interests_subtitle"
        android:textColor="@color/text_muted"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvSelectionMeta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/orange_dark"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:text="0 of 3 selected" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvInterests"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="always"
        android:paddingBottom="12dp" />

    <Button
        android:id="@+id/btnContinueInterests"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="@color/orange"
        android:text="@string/continue_to_home"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/tvSkipInterests"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="@string/skip_for_now"
        android:textColor="@color/text_muted"
        android:textSize="13sp" />

</LinearLayout>
